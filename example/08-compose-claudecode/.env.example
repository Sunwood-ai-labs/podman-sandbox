# Claude Code + Alibaba Qwen 環境設定
# https://www.alibabacloud.com/help/en/model-studio/claude-code

# Alibaba Cloud Coding Plan API キー (必須)
# https://dashscope.console.aliyun.com/ から取得
# ※ Coding Plan 用の専用エンドポイントを使用
ALIBABA_API_KEY=sk-your-coding-plan-api-key-here

# 使用する Qwen モデル (オプション)
# 推奨: qwen3.5-plus (複雑なタスク), qwen3-coder-next (コーディング)
# その他: qwen3-max, qwen-turbo, qwen3.5-flash
CLAUDE_MODEL=qwen3.5-plus

# 作業ディレクトリ設定 (オプション)
WORKSPACE_PATH=/workspace
